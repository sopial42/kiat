# Kiat — env template
#
# Copy to `.env` (gitignored) and fill in the secrets. The Makefile includes
# `.env` automatically; docker-compose reads it too.
#
# Production values live in your secret manager (Cloud Run env, Vault, etc.)
# and are NOT set in this file — this is local dev / test only.

# ─── Environment selector ───────────────────────────────────────
# `local` / `local-test` / `e2e` / `production`
# `production` triggers the fatal guards in backend/cmd/api/main.go init().
ENV=local

# ─── Database ───────────────────────────────────────────────────
POSTGRES_DB=kiat
POSTGRES_USER=kiat
POSTGRES_PASSWORD=kiat_dev
POSTGRES_PORT=5432
DATABASE_URL=postgres://kiat:kiat_dev@localhost:5432/kiat?sslmode=disable

# ─── MinIO (S3-compatible object storage) ───────────────────────
MINIO_ROOT_USER=kiat_minio
MINIO_ROOT_PASSWORD=kiat_minio_dev
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── Smocker (E2E external mocks only — do NOT set in production) ──
SMOCKER_PORT=8100
SMOCKER_ADMIN_PORT=8101

# ─── Clerk authentication ───────────────────────────────────────
# Get from https://dashboard.clerk.com — use dev instance keys locally.
# Do NOT commit real values; leave placeholders in .env.example.
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk JWT template used by Playwright global.setup.ts to swap the Testing Token
# for a long-lived JWT. Create this template in Clerk dev dashboard, lifetime 3600s.
CLERK_PLAYWRIGHT_JWT_TEMPLATE=playwright-ci

# ─── Test auth bypass (MUST be false in production) ─────────────
# When true: backend accepts X-Test-User-Id header; frontend wires TestAuthProvider.
# main.go init() crashes at startup if ENV=production and this is true.
ENABLE_TEST_AUTH=false
NEXT_PUBLIC_ENABLE_TEST_AUTH=false

# ─── External API upstreams ─────────────────────────────────────
# Per-source BASE_URL. Smocker is the universal mock in every non-production
# mode (dev-offline / test-venom / test-e2e) — see delivery/specs/smocker-patterns.md.
#
# Set production URLs below. The Makefile targets for non-production modes
# override each EXTERNAL_*_BASE_URL to http://localhost:8100/<slug> automatically.
#
# In production, main.go init() crashes if any EXTERNAL_*_BASE_URL contains
# "smocker", "localhost:8100", or "127.0.0.1:8100".
#
# Only needed when you introduce an external upstream in EPIC 02+; leave
# commented for now (EPIC 00 and EPIC 01 don't call any external API).
#
# Example (uncomment and duplicate per upstream):
# EXTERNAL_A_BASE_URL=https://api.external-a.example
# EXTERNAL_B_BASE_URL=https://other-upstream.example

# ─── Playwright E2E ─────────────────────────────────────────────
E2E_BASE_URL=http://localhost:3100
E2E_USER_A_EMAIL=user-a@example.com
E2E_USER_A_PASSWORD=REPLACE_ME
E2E_USER_A_CLERK_ID=user_REPLACE_ME
E2E_USER_B_EMAIL=user-b@example.com
E2E_USER_B_PASSWORD=REPLACE_ME
E2E_USER_B_CLERK_ID=user_REPLACE_ME
