# Runtime data written by Team Lead during real stories
# (The schema lives in .claude/specs/metrics-events.md and is committed.
# The data itself is project-specific and should never be in the Kiat repo.)
delivery/metrics/*.jsonl

# Python bytecode from running the framework tools
__pycache__/
*.pyc
*.pyo
*.pyd

# Editor / OS cruft
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Generated reports (ephemeral — regenerate with report.py / doc-audit.py)
*-report.md
doc-audit.md
health-report.md

# Env secrets (use .env.example as template)
.env
.env.local
.env.*.local

# Playwright artifacts
frontend/playwright/.clerk/
frontend/playwright-report/
frontend/test-results/
frontend/.next/
frontend/node_modules/

# Backend build artifacts
backend/bin/
backend/tmp/

# External Claude Code skills installed by `make install-claude-skills`.
# Source-of-truth is skills-lock.json; the installed copies are reproducible
# from the pinned SHAs. Never commit them — the lock file's computedHash
# guarantees integrity, and ignoring them keeps the repo tidy + lets the
# install script overwrite cleanly without merge conflicts.
.claude/.skills-cache/
.claude/skills/differential-review/
.claude/skills/sharp-edges/
.claude/skills/frontend-design/
.claude/skills/react-best-practices/
.claude/skills/composition-patterns/

# Test coverage
coverage/
*.out
*.cover
